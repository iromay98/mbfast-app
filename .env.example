# このファイルをコピーして .env を作成してください: cp .env.example .env
# 実際の値はコミットしないこと。

# ── データベース ──────────────────────────────
# 開発(ポータブル版 PostgreSQL / scripts/pg.sh):
DATABASE_URL="postgresql://postgres@127.0.0.1:5432/mbfast?schema=public"
# 本番(VPS の PostgreSQL)例:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mbfast?schema=public&sslmode=require"

# ── 認証 (Auth.js) ────────────────────────────
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="change-me-to-a-32byte-random-base64"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ── ファイルストレージ ────────────────────────
# local: VPS のローカルディスク（Web 公開ディレクトリの外）。将来 s3 に差し替え可。
# 【永続化・重要】STORAGE_LOCAL_DIR と PostgreSQL データ領域は、アプリのコード/デプロイ領域とは
# 別の「永続ボリューム」を指すこと。デプロイ(コード更新)でアップロード済みファイルや DB が
# 消えたり再生成されたりしてはならない。本番例: STORAGE_LOCAL_DIR="/srv/mbfast/storage"（コード外）。
# 配信は必ず認可付きエンドポイント経由（公開ディレクトリには絶対に置かない）。
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"
MAX_UPLOAD_BYTES="52428800" # 50MB

# ── 通知 ──────────────────────────────────────
# console: コンソール出力スタブ（MVP）。本番は line。
NOTIFICATION_DRIVER="console"
# LINE_CHANNEL_ACCESS_TOKEN=""

# ── mbPIT 施工ブログ自動公開（WordPress: mbfasttuning.com） ──
# 認証は Application Password の Basic 認証。コードに直書きせずここで設定する。
WP_BASE_URL="https://mbfasttuning.com"
WP_USER=""
WP_APP_PASSWORD=""
# 記事生成/ナンバープレート検出に使うモデル（省略時 claude-sonnet-5）
# PIT_ARTICLE_MODEL="claude-sonnet-5"
# PIT_VISION_MODEL="claude-sonnet-5"
# 施工ジャンルカテゴリID（任意・JSON）。未設定ならジャンルカテゴリは付与しない。
# PIT_GENRE_CATEGORY_IDS='{"ECU":557,"COATING":559,"POLISH":561,"MAINTENANCE":563,"OTHER":565}'

# ── AI（Claude API）。mbPIT 記事生成・ECU識別子抽出で使用 ──
ANTHROPIC_API_KEY=""

# ── AutoTuner Master API（スレーブ自動復号） ──
# X-Autotuner-Id: 本店マスター機器ID（8桁hex, 例 20104321）
# X-Autotuner-API-Key: Autotuner サポートから受領する秘密鍵
AUTOTUNER_API_BASE="https://api.autotuner-tool.com/v2/api/v1/master"
AUTOTUNER_ID=""
AUTOTUNER_API_KEY=""
AUTOTUNER_TIMEOUT_MS="30000"
AUTOTUNER_MAX_RETRIES="5"
